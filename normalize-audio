#!/usr/bin/env bash
# normalize-audio — normalize video/audio loudness to EBU R128 (-16 LUFS)
# Part of videonorma: https://github.com/prostopasta/videonorma
#
# Usage: normalize-audio <file> [file2 ...]
# Output: <name>_normalized.<ext> alongside the original

set -euo pipefail

# Verify ffmpeg-normalize is available
if ! command -v ffmpeg-normalize &>/dev/null; then
    echo "Error: ffmpeg-normalize not found." >&2
    echo "Install it with:  pipx install ffmpeg-normalize" >&2
    echo "Or run:           bash install.sh" >&2
    exit 1
fi

# Verify ffmpeg is available
if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg not found." >&2
    echo "Install it with your package manager:" >&2
    echo "  Ubuntu/Debian:  sudo apt install ffmpeg" >&2
    echo "  Fedora:         sudo dnf install ffmpeg" >&2
    echo "  Arch:           sudo pacman -S ffmpeg" >&2
    exit 1
fi

VERSION="1.2.5"

usage() {
    cat <<'EOF'
Usage: normalize-audio [OPTIONS] <file> [file2 ...]

Normalize video/audio loudness to EBU R128 (-16 LUFS, broadcast standard).
The original file is never modified.
Output: <name>_normalized.<ext> alongside the source file.

Options:
  -h, --help       Show this help message and exit
  -V, --version    Show version and exit

Examples:
  normalize-audio recording.mov
  normalize-audio *.mp4
  normalize-audio ~/Downloads/meeting.mov ~/Videos/demo.mkv

Normalization settings:
  Target level   -16 LUFS  (EBU R128)
  True peak      -1.5 dBTP
  LRA            11 LU
  Video          stream copy (no re-encode, no quality loss)
  Audio          AAC 192 kbps

Supported formats:
  .mov  .mp4  .mkv  .webm  .avi  .m4v  .ts  .wmv  .flv

More info: https://github.com/prostopasta/videonorma
EOF
}

for arg in "$@"; do
    case "$arg" in
        -h|--help)    usage; exit 0 ;;
        -V|--version) echo "normalize-audio $VERSION"; exit 0 ;;
    esac
done

[[ $# -eq 0 ]] && usage && exit 1

for INPUT in "$@"; do
    [[ ! -f "$INPUT" ]] && echo "Not found: $INPUT" && continue

    DIR=$(dirname "$INPUT")
    BASE=$(basename "$INPUT")
    EXT="${BASE##*.}"
    NAME="${BASE%.*}"
    OUTPUT="$DIR/${NAME}_normalized.${EXT}"

    echo ""
    echo "▶ $BASE"
    echo "  → $(basename "$OUTPUT")"

    ffmpeg-normalize "$INPUT" \
        --normalization-type ebu \
        --target-level -16 \
        --true-peak -1.5 \
        --loudness-range-target 11 \
        --video-codec copy \
        --audio-codec aac \
        --audio-bitrate 192k \
        -o "$OUTPUT"

    echo "  ✓ Done"
done

echo ""
echo "All files processed."
