INDICATOR_AVAILABLE = False
AppIndicator = None
for _ns, _ver in (("AyatanaAppIndicator3", "0.1"), ("AppIndicator3", "0.1")):
    try:
        gi.require_version(_ns, _ver)
        from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: F401,E402
        INDICATOR_AVAILABLE = True
        break
    except (ValueError, ImportError):
        pass

# ── Constants ─────────────────────────────────────────────────────────────────
VERSION = "2.0.0"
APP_NAME = "videonorma"
VIDEO_EXTENSIONS = frozenset(
    {".mov", ".mp4", ".mkv", ".webm", ".avi", ".m4v", ".ts", ".wmv", ".flv"}
)
IGNORE_SUFFIXES = frozenset({".crdownload", ".part", ".tmp", ".download"})
CONFIG_DIR = Path.home() / ".config" / APP_NAME
CONFIG_FILE = CONFIG_DIR / "config.json"
LOG_FILE = Path("/tmp/videonorma-daemon.log")
ASSETS_DIR = Path(__file__).resolve().parent.parent / "assets"

DEFAULT_CONFIG: dict = {
    "enabled": True,
    "watch_dirs": [str(Path.home() / "Downloads")],
    "auto_normalize": False,
    "open_after": True,
    "icon_variant": "auto",   # "auto" | "dark-panel" | "light-panel"
}

# ── Logging ───────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s  %(levelname)-8s %(message)s",
    datefmt="%H:%M:%S",
    handlers=[
        logging.FileHandler(LOG_FILE, encoding="utf-8"),
        logging.StreamHandler(sys.stdout),
    ],
)
log = logging.getLogger(APP_NAME)


# ── Config ────────────────────────────────────────────────────────────────────
def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return {**DEFAULT_CONFIG, **json.loads(CONFIG_FILE.read_text())}
        except Exception as exc:
            log.warning("Config parse error (%s) — using defaults", exc)
    return dict(DEFAULT_CONFIG)


def save_config(cfg: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))


# ── Notifications ─────────────────────────────────────────────────────────────
def _notify_send(*args: str) -> None:
    try:
        subprocess.run(
            ["notify-send", "--app-name=videonorma", "-i", "video-x-generic", *args],
            check=False,
            capture_output=True,
        )
    except FileNotFoundError:
        pass


def notify(title: str, body: str, timeout_ms: int = 4000) -> None:
    _notify_send("-t", str(timeout_ms), title, body)


def notify_action(title: str, body: str, timeout_s: int = 25) -> str | None:
    """
    Show a notification with Normalize / Skip action buttons.
    Blocks until the user clicks or the notification is dismissed.
    Returns 'normalize', 'skip', or None (dismissed / timed out).
    """
    args = [
        "--wait",
        "--action", "normalize=Normalize",
        "--action", "skip=Skip",
        "-t", str(timeout_s * 1000),
        title,
        body,
    ]
    try:
        result = subprocess.run(
            ["notify-send", "--app-name=videonorma", "-i", "video-x-generic", *args],
            capture_output=True,
            text=True,
            timeout=timeout_s + 5,
        )
        return result.stdout.strip() or None
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return None


# ── Normalizer ────────────────────────────────────────────────────────────────
def normalize_file(path: Path, open_after: bool) -> None:
    """Normalize *path* in a daemon thread; notify on completion."""

    def _run() -> None:
        log.info("Normalizing: %s", path.name)
        notify("videonorma", f"Normalizing: {path.name}\nThis may take ~30 s…", 6000)
        try:
            result = subprocess.run(
                ["normalize-audio", str(path)],
                capture_output=True,
                text=True,
            )
        except FileNotFoundError:
            log.error("normalize-audio not found — run install.sh")
            notify("videonorma ✗", "normalize-audio not found. Run install.sh again.", 8000)
            return

        out_path = path.parent / f"{path.stem}_normalized{path.suffix}"
        if result.returncode == 0 and out_path.exists():
            log.info("Done: %s", out_path.name)
            notify("videonorma ✓", f"Done: {out_path.name}", 5000)
            if open_after:
                subprocess.Popen(
                    ["xdg-open", str(out_path)],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
        else:
            log.error("normalize-audio failed:\n%s", result.stderr)
            notify("videonorma ✗", f"Error normalizing {path.name}\nSee {LOG_FILE}", 8000)

    threading.Thread(target=_run, daemon=True, name=f"norm-{path.stem}").start()


# ── File stability check ──────────────────────────────────────────────────────
def _wait_until_stable(path: Path, interval: float = 2.0, stable_rounds: int = 2,
                       timeout: float = 300.0) -> bool:
    """
    Poll file size until it stops growing for `stable_rounds` consecutive checks.
    Returns True when stable, False on timeout or file disappearance.
    Used for files written directly to their final name (not via .crdownload rename).
    """
    deadline = time.monotonic() + timeout
    prev_size = -1
    stable = 0
    while time.monotonic() < deadline:
        try:
            size = path.stat().st_size
        except OSError:
            return False
        if size > 0 and size == prev_size:
            stable += 1
            if stable >= stable_rounds:
                log.debug("File stable at %d bytes: %s", size, path.name)
                return True
        else:
            stable = 0
        prev_size = size
        time.sleep(interval)
    log.warning("Stability timeout for %s (still changing after %.0fs)", path.name, timeout)
    return False


# ── File watcher ──────────────────────────────────────────────────────────────
class VideoHandler(FileSystemEventHandler):
    """Triggers on fully-written video files; skips already-normalized outputs."""

    def __init__(self, get_cfg):
        self._get_cfg = get_cfg
        # path → True means "via on_moved" (already complete, skip stability check)
        self._seen: dict[str, bool] = {}
        self._lock = threading.Lock()

    # ── helpers ────────────────────────────────────────────────────────────
    def _is_new_video(self, path_str: str) -> bool:
        p = Path(path_str)
        return (
            p.suffix.lower() in VIDEO_EXTENSIONS
            and p.suffix.lower() not in IGNORE_SUFFIXES
            and "_normalized" not in p.stem
            and not p.name.startswith(".")
        )

    def _dispatch(self, path_str: str, already_complete: bool = False) -> None:
        with self._lock:
            if path_str in self._seen:
                return
            self._seen[path_str] = already_complete

        cfg = self._get_cfg()
        if not cfg.get("enabled", True):
            log.debug("Watcher disabled — ignoring %s", Path(path_str).name)
            with self._lock:
                self._seen.pop(path_str, None)
            return

        path = Path(path_str)
        log.info("New video detected: %s (complete=%s)", path.name, already_complete)

        def _ask():
            if not already_complete:
                # on_closed can fire mid-download if the file is opened/closed
                # multiple times — wait until size is stable.
                log.debug("Waiting for %s to finish writing…", path.name)
                if not _wait_until_stable(path):
                    log.warning("Giving up on %s (never stabilised)", path.name)
                    with self._lock:
                        self._seen.pop(path_str, None)
                    return

            with self._lock:
                self._seen.pop(path_str, None)

            if not path.exists():
                return

            cfg = self._get_cfg()
            if cfg.get("auto_normalize"):
                normalize_file(path, cfg.get("open_after", True))
                return

            action = notify_action("New video in Downloads", path.name)
            if action == "normalize":
                normalize_file(path, cfg.get("open_after", True))
            else:
                log.debug("Skipped: %s", path.name)

        threading.Thread(target=_ask, daemon=True, name=f"ask-{path.stem}").start()

    # ── watchdog events ────────────────────────────────────────────────────
    def on_closed(self, event):
        """Fires when a file descriptor is closed after writing (Linux inotify).
        May fire multiple times during an active download — _wait_until_stable handles it."""
        if not event.is_directory and self._is_new_video(event.src_path):
            self._dispatch(event.src_path, already_complete=False)

    def on_moved(self, event):
        """Fires when a browser renames foo.crdownload → foo.mp4.
        The file is 100% complete at this point — skip stability check."""
        if not event.is_directory and self._is_new_video(event.dest_path):
            self._dispatch(event.dest_path, already_complete=True)


# ── Theme detection ───────────────────────────────────────────────────────────
def _detect_panel_dark() -> bool:
    """
    Return True if the system panel/tray background is dark (→ use light icon).

    Checks in order:
    1. org.gnome.desktop.interface color-scheme  ('prefer-dark' → dark panel)
    2. org.gnome.desktop.interface gtk-theme     (name contains 'dark')
    3. Ubuntu default: Yaru on Ubuntu always has a dark top-bar regardless of
       color-scheme, so fall back to True (dark panel = light icon needed).
    """
    try:
        result = subprocess.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
            capture_output=True, text=True, check=False,
        )
        if "prefer-dark" in result.stdout:
            return True
    except FileNotFoundError:
        pass

    try:
        result = subprocess.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "gtk-theme"],
            capture_output=True, text=True, check=False,
        )
        if "dark" in result.stdout.lower():
            return True
    except FileNotFoundError:
        pass

    # Ubuntu's GNOME Shell top bar is dark even in "light" mode (Yaru theme).
    # Default safe: assume dark panel → use light icon.
    return True


def _icon_for_variant(variant: str) -> str:
    """
    Resolve the icon file path for the given variant.
    variant: 'auto' | 'dark-panel' | 'light-panel'
    """
    if variant == "auto":
        use_dark_panel = _detect_panel_dark()
    else:
        use_dark_panel = (variant == "dark-panel")

    name = "icon-on-dark.svg" if use_dark_panel else "icon-on-light.svg"
    candidate = ASSETS_DIR / name
    if candidate.exists():
        return str(candidate)
    # Fallback to logo or generic
    fallback = ASSETS_DIR / "logo.svg"
    return str(fallback) if fallback.exists() else "video-x-generic"


# ── Tray icon ─────────────────────────────────────────────────────────────────
class Tray:
    _VARIANT_LABELS = {
        "auto":        "Auto (follow system)",
        "dark-panel":  "Light icon  (dark panel)",
        "light-panel": "Dark icon  (light panel)",
    }

    def __init__(self, get_cfg, save_cfg, quit_fn):
        self._get_cfg = get_cfg
        self._save_cfg = save_cfg
        self._quit = quit_fn
        self._indicator = None
        self._gsettings = None

        if not INDICATOR_AVAILABLE:
            log.warning("AppIndicator not available — tray icon disabled")
            return

        cfg = get_cfg()
        icon = _icon_for_variant(cfg.get("icon_variant", "auto"))
        log.debug("Tray icon: %s", icon)

        self._indicator = AppIndicator.Indicator.new(
            APP_NAME,
            icon,
            AppIndicator.IndicatorCategory.APPLICATION_STATUS,
        )
        self._indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self._indicator.set_menu(self._build_menu())

        # Watch GNOME color-scheme changes (auto mode)
        self._attach_theme_watcher()

    # ── GLib.Settings theme watcher ────────────────────────────────────────
    def _attach_theme_watcher(self) -> None:
        try:
            self._gsettings = Gio.Settings.new("org.gnome.desktop.interface")
            self._gsettings.connect("changed::color-scheme", self._on_system_theme_changed)
            self._gsettings.connect("changed::gtk-theme",    self._on_system_theme_changed)
        except Exception as exc:
            log.debug("Could not attach theme watcher: %s", exc)

    def _on_system_theme_changed(self, _settings, _key) -> None:
        cfg = self._get_cfg()
        if cfg.get("icon_variant", "auto") == "auto":
            GLib.idle_add(self._refresh_icon)

    def _refresh_icon(self) -> bool:
        cfg = self._get_cfg()
        icon = _icon_for_variant(cfg.get("icon_variant", "auto"))
        log.debug("Refreshing tray icon → %s", icon)
        if self._indicator:
            self._indicator.set_icon_full(icon, "videonorma")
        return False  # one-shot GLib source

    # ── Menu ───────────────────────────────────────────────────────────────
    def _build_menu(self) -> Gtk.Menu:
        cfg = self._get_cfg()
        menu = Gtk.Menu()

        lbl = Gtk.MenuItem(label=f"videonorma  v{VERSION}")
        lbl.set_sensitive(False)
        menu.append(lbl)
        menu.append(Gtk.SeparatorMenuItem())

        self._watch_item = Gtk.CheckMenuItem(label="Watch ~/Downloads")
        self._watch_item.set_active(cfg.get("enabled", True))
        self._watch_item.connect("toggled", self._on_watch_toggle)
        menu.append(self._watch_item)

        self._auto_item = Gtk.CheckMenuItem(label="Auto-normalize (no prompt)")
        self._auto_item.set_active(cfg.get("auto_normalize", False))
        self._auto_item.connect("toggled", self._on_auto_toggle)
        menu.append(self._auto_item)

        menu.append(Gtk.SeparatorMenuItem())

        # Icon theme submenu
        icon_menu_item = Gtk.MenuItem(label="Icon theme")
        icon_submenu = Gtk.Menu()
        current_variant = cfg.get("icon_variant", "auto")
        self._icon_radio_group: list[Gtk.RadioMenuItem] = []

        prev = None
        for variant, label in self._VARIANT_LABELS.items():
            item = Gtk.RadioMenuItem.new_with_label(
                [prev] if prev else [], label
            )
            if variant == current_variant:
                item.set_active(True)
            item.connect("toggled", self._on_icon_variant_toggled, variant)
            icon_submenu.append(item)
            self._icon_radio_group.append(item)
            prev = item

        icon_menu_item.set_submenu(icon_submenu)
        menu.append(icon_menu_item)

        menu.append(Gtk.SeparatorMenuItem())

        log_item = Gtk.MenuItem(label="Open log…")
        log_item.connect("activate", lambda _: subprocess.Popen(
            ["xdg-open", str(LOG_FILE)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        ))
        menu.append(log_item)

        menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", lambda _: self._quit())
        menu.append(quit_item)

        menu.show_all()
        return menu

    # ── Handlers ───────────────────────────────────────────────────────────
    def _on_watch_toggle(self, item: Gtk.CheckMenuItem) -> None:
        cfg = self._get_cfg()
        cfg["enabled"] = item.get_active()
        self._save_cfg(cfg)
        state = "enabled" if cfg["enabled"] else "paused"
        log.info("Watching %s", state)
        notify("videonorma", f"Watching {state}")

    def _on_auto_toggle(self, item: Gtk.CheckMenuItem) -> None:
        cfg = self._get_cfg()
        cfg["auto_normalize"] = item.get_active()
        self._save_cfg(cfg)
        log.info("Auto-normalize: %s", cfg["auto_normalize"])

    def _on_icon_variant_toggled(self, item: Gtk.RadioMenuItem, variant: str) -> None:
        if not item.get_active():
            return
        cfg = self._get_cfg()
        cfg["icon_variant"] = variant
        self._save_cfg(cfg)
        log.info("Icon variant: %s", variant)
        GLib.idle_add(self._refresh_icon)


# ── Daemon ────────────────────────────────────────────────────────────────────
class Daemon:
    def __init__(self, no_tray: bool = False):
        self._cfg = load_config()
        self._no_tray = no_tray
        self._observer: Observer | None = None

    def _get_cfg(self) -> dict:
        return self._cfg

    def _save_cfg(self, cfg: dict) -> None:
        self._cfg = cfg
        save_config(cfg)

    def start(self) -> None:
        log.info("videonorma daemon v%s starting", VERSION)
        log.info("Config: %s", CONFIG_FILE)
        log.info("Log:    %s", LOG_FILE)

        # File watcher
        handler = VideoHandler(self._get_cfg)
        self._observer = Observer()
        for d in self._cfg["watch_dirs"]:
            p = Path(d).expanduser()
            if p.is_dir():
                self._observer.schedule(handler, str(p), recursive=False)
                log.info("Watching: %s", p)
            else:
                log.warning("Watch dir not found, skipping: %s", p)
        self._observer.start()

        # Tray
        tray = None if self._no_tray else Tray(self._get_cfg, self._save_cfg, self._stop_gtk)

        # Signal handlers (SIGTERM from systemd, SIGINT from Ctrl-C)
        signal.signal(signal.SIGTERM, lambda *_: GLib.idle_add(self._stop_gtk))
        signal.signal(signal.SIGINT,  lambda *_: GLib.idle_add(self._stop_gtk))

        notify("videonorma", "Running — watching ~/Downloads", 3000)

        if INDICATOR_AVAILABLE and not self._no_tray:
            Gtk.main()
        else:
            try:
                while self._observer.is_alive():
                    time.sleep(1)
            except KeyboardInterrupt:
                pass

        self._shutdown()

    def _stop_gtk(self) -> bool:
        if INDICATOR_AVAILABLE:
            Gtk.main_quit()
        return False  # remove GLib source

    def _shutdown(self) -> None:
        log.info("Shutting down")
        if self._observer:
            self._observer.stop()
            self._observer.join(timeout=5)


# ── CLI ───────────────────────────────────────────────────────────────────────
def main() -> None:
    parser = argparse.ArgumentParser(
        description="videonorma daemon — normalizes new videos in ~/Downloads"
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    parser.add_argument("--debug",   action="store_true", help="Verbose logging")
    parser.add_argument("--no-tray", action="store_true", help="Disable tray icon")
    args = parser.parse_args()

    if args.debug:
        logging.getLogger().setLevel(logging.DEBUG)

    Daemon(no_tray=args.no_tray).start()


if __name__ == "__main__":
    main()
