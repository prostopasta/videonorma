    from watchdog.observers import Observer
    from watchdog.events import FileSystemEventHandler
except ImportError:
    sys.exit(
        "ERROR: watchdog not installed.\n"
        "  Ubuntu/Debian: sudo apt install python3-watchdog\n"
        "  Fedora:        sudo dnf install python3-watchdog\n"
        "  Arch:          sudo pacman -S python-watchdog"
    )

