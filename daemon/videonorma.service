[Unit]
Description=videonorma — video loudness normalization daemon
Documentation=https://github.com/prostopasta/videonorma
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/videonorma-daemon
Restart=on-failure
RestartSec=10

# Predictable systemd user paths (%U = numeric UID)
Environment=XDG_RUNTIME_DIR=/run/user/%U
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/%U/bus

[Install]
WantedBy=graphical-session.target
